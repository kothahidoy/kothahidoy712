ating, review) => {\n      const userId = await getCurrentUserId();\n      if (userId && _srcLibSupabase.supabase) {\n        await _srcLibSupabase.supabase.from(\"bookings\").update({\n          rating,\n          review\n        }).eq(\"id\", id).eq(\"customer_id\", userId);\n        return;\n      }\n      const all = await readJSON(BOOKINGS_KEY, []);\n      await writeJSON(BOOKINGS_KEY, all.map(b => b.id === id ? Object.assign({}, b, {\n        rating,\n        review\n      }) : b));\n    },\n    markCompleted: async id => {\n      const userId = await getCurrentUserId();\n      if (userId && _srcLibSupabase.supabase) {\n        await _srcLibSupabase.supabase.from(\"bookings\").update({\n          status: \"completed\"\n        }).eq(\"id\", id).eq(\"customer_id\", userId);\n        return;\n      }\n      const all = await readJSON(BOOKINGS_KEY, []);\n      await writeJSON(BOOKINGS_KEY, all.map(b => b.id === id ? Object.assign({}, b, {\n        status: \"completed\"\n      }) : b));\n    },\n    // --- ADDRESSES --------------------------------------------------------\n\n    listAddresses: async () => {\n      const userId = await getCurrentUserId();\n      if (userId && _srcLibSupabase.supabase) {\n        const {\n          data,\n          error\n        } = await _srcLibSupabase.supabase.from(\"saved_addresses\").select(\"id, label, address_line, landmark, city, latitude, longitude, is_default\").eq(\"user_id\", userId).order(\"created_at\", {\n          ascending: false\n        });\n        if (!error && data) {\n          return data.map(a => ({\n            id: a.id,\n            label: a.label ?? \"Home\",\n            addressLine: a.address_line,\n            landmark: a.landmark ?? undefined,\n            city: a.city,\n            latitude: Number(a.latitude ?? 0),\n            longitude: Number(a.longitude ?? 0),\n            isDefault: !!a.is_default\n          }));\n        }\n      }\n      return readJSON(ADDRESSES_KEY, []);\n    },\n    saveA